{
  "functions": {
    "api/parse-import-batch.js": {
      "maxDuration": 60
    },
    "api/generate-social-post.js": {
      "maxDuration": 60
    },
    "api/assistant.js": {
      "maxDuration": 30
    },
    "api/transcribe.js": {
      "maxDuration": 25
    },
    "api/parse-voice-note.js": {
      "maxDuration": 30
    },
    "api/parse-lead.js": {
      "maxDuration": 30
    },
    "api/generate-message.js": {
      "maxDuration": 30
    },
    "api/google-auth.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "microphone=(self)"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ]
}
